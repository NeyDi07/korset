# Körset — Environment Variables
# Скопируй в .env.local для локальной разработки
# В Vercel добавь через Settings → Environment Variables

# Supabase (клиентские — видны в браузере, это ОК для anon key)
VITE_SUPABASE_URL=https://ТВОЙ_ПРОЕКТ.supabase.co
VITE_SUPABASE_ANON_KEY=ТВОЙ_ANON_KEY

# OpenAI GPT-4o-mini (ТОЛЬКО серверный — НЕ добавляй VITE_ префикс!)
# Доступен ТОЛЬКО в Vercel API routes (api/ai.js), клиент НЕ видит
OPENAI_API_KEY=sk-your-openai-api-key
